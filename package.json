{
  "name": "optcar-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "db:seed": "node scripts/seed-rtdb.mjs",
    "db:rules:check": "node -e \"JSON.parse(require('fs').readFileSync('database.rules.json','utf8')); console.log('database.rules.json OK')\"",
    "postinstall": "node scripts/fix-expo-router-ctx.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-font": "~14.0.9",
    "expo-router": "~6.0.23",
    "firebase": "^12.11.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  }
}
